  {
    name: "The Red Pollack",
    handle: "feral-golf-the-red-pollack-ferrule-abstract-paint-splatter",
    tagline: "Warm chaos. Red-hot swagger.",
    tags: {earth:1, cool:0, bold:3, neutral:0, outdoorsy:0, creative:3, wild:1, minimal:0, statement:2, personal:2, clean:0}
  },
  {
    name: "The Wave",
    handle: "feral-golf-the-wave-golf-ferrule",
    tagline: "Ride the gradient. Stay cool.",
    tags: {earth:0, cool:3, bold:1, neutral:1, outdoorsy:0, creative:2, wild:0, minimal:1, statement:1, personal:1, clean:2}
  }
];

// ═══════════════════════════════════════════════════════════════
// RESULT HEADLINE COPY — based on dominant tag
// ═══════════════════════════════════════════════════════════════
const PYF_HEADLINES = {
  wild:      ["Certified Chaotic Good", "Pure Feral Energy"],
  bold:      ["Maximum Statement. Zero Apologies.", "Built to Be Seen"],
  creative:  ["Artist on the Fairway", "You See the Course Differently"],
  outdoorsy: ["Born in the Wild. Plays in the Wild.", "Tactical. Grounded. Feral."],
  minimal:   ["Precision Over Everything", "Clean Game. Sharp Clubs."],
  cool:      ["Cool Runs Deep", "Ocean Energy. Every Round."],
  earth:     ["Rooted. Tactical. Feral.", "Earthy by Nature. Wild by Choice."],
  clean:     ["Sharp. Dialed. Dangerous.", "Clean Clubs. Loud Game."],
  personal:  ["Unmistakably You", "Your Story. On Every Club."],
  statement: ["The Double-Take Is the Point", "They Will Notice."]
};

// ═══════════════════════════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════════════════════════
let pyfScores = {};
let pyfCurrentQ = 0;
const PYF_TOTAL = PYF_QUESTIONS.length;

function pyfResetScores() {
  pyfScores = {earth:0,cool:0,bold:0,neutral:0,outdoorsy:0,creative:0,wild:0,minimal:0,statement:0,personal:0,clean:0};
}

// ═══════════════════════════════════════════════════════════════
// SCORING
// ═══════════════════════════════════════════════════════════════
function pyfScoreFerrule(ferrule) {
  return Object.keys(ferrule.tags).reduce((sum, tag) => {
    return sum + (ferrule.tags[tag] || 0) * (pyfScores[tag] || 0);
  }, 0);
}

function pyfGetTopFerrules(n) {
  return PYF_FERRULES
    .map(f => ({ ...f, score: pyfScoreFerrule(f) }))
    .sort((a, b) => b.score - a.score)
    .slice(0, n);
}

function pyfDominantTag() {
  return Object.keys(pyfScores).reduce((a, b) => pyfScores[a] >= pyfScores[b] ? a : b);
}

// ═══════════════════════════════════════════════════════════════
// FLOW
// ═══════════════════════════════════════════════════════════════
function pyfStart() {
  pyfResetScores();
  pyfCurrentQ = 0;
  document.getElementById('pyf-hero').style.display = 'none';
  document.getElementById('pyf-results').style.display = 'none';
  document.getElementById('pyf-quiz').style.display = 'block';
  pyfRenderQuestion();
}

function pyfRestart() {
  document.getElementById('pyf-results').style.display = 'none';
  pyfStart();
}

function pyfSelectAnswer(answerIndex) {
  const q = PYF_QUESTIONS[pyfCurrentQ];
  const answer = q.answers[answerIndex];

  // Apply tags
  Object.keys(answer.tags).forEach(tag => {
    pyfScores[tag] = (pyfScores[tag] || 0) + answer.tags[tag];
  });

  // Flash selected state briefly
  const cards = document.querySelectorAll('.pyf-answer');
  if (cards[answerIndex]) {
    cards[answerIndex].classList.add('selected');
  }

  setTimeout(() => {
    pyfCurrentQ++;
    if (pyfCurrentQ < PYF_TOTAL) {
      pyfRenderQuestion();
    } else {
      pyfShowResults();
    }
  }, 280);
}

function pyfRenderQuestion() {
  const q = PYF_QUESTIONS[pyfCurrentQ];
  const pct = (pyfCurrentQ / PYF_TOTAL) * 100;
  document.getElementById('pyf-progress-fill').style.width = pct + '%';
  document.getElementById('pyf-progress-label').textContent = (pyfCurrentQ + 1) + ' / ' + PYF_TOTAL;

  const wrap = document.getElementById('pyf-question-wrap');
  wrap.innerHTML = `
    <div class="pyf-question">
      <div class="pyf-q-eyebrow">${q.eyebrow}</div>
      <div class="pyf-q-text">${q.text}</div>
      <div class="pyf-answers">
        ${q.answers.map((a, i) => `
          <button class="pyf-answer" onclick="pyfSelectAnswer(${i})">
            <div class="pyf-answer-icon">${a.icon}</div>
            <div>
              <div class="pyf-answer-text">${a.text}</div>
              ${a.sub ? `<div class="pyf-answer-sub">${a.sub}</div>` : ''}
            </div>
          </button>
        `).join('')}
      </div>
    </div>
  `;
}

// ═══════════════════════════════════════════════════════════════
// RESULTS
// ═══════════════════════════════════════════════════════════════
async function pyfShowResults() {
  document.getElementById('pyf-quiz').style.display = 'none';
  document.getElementById('pyf-results').style.display = 'block';

  const topFerrules = pyfGetTopFerrules(3);
  const dom = pyfDominantTag();
  const headlines = PYF_HEADLINES[dom] || ["Your Feral Ferrules"];
  const headline = headlines[Math.floor(Math.random() * headlines.length)];

  document.getElementById('pyf-results-headline').textContent = headline;
  document.getElementById('pyf-results-sub').textContent =
    "Based on your answers, here are the ferrules built for your game.";

  const grid = document.getElementById('pyf-product-grid');
  grid.innerHTML = '<div style="grid-column:1/-1;text-align:center;color:var(--pyf-muted);padding:20px">Loading your matches...</div>';

  const cards = await Promise.all(topFerrules.map((f, i) => pyfBuildCard(f, i === 0)));
  grid.innerHTML = cards.join('');
}

async function pyfBuildCard(ferrule, isTopPick) {
  if (ferrule.comingSoon) {
    return `
      <div class="pyf-product-card coming-soon" style="position:relative">
        <span class="pyf-coming-badge">Coming Soon</span>
        <div class="pyf-product-img-wrap">
          <div class="pyf-product-img-placeholder">⚡</div>
        </div>
        <div class="pyf-product-body">
          <div class="pyf-product-name">${ferrule.name}</div>
          <div class="pyf-product-tagline">${ferrule.tagline}</div>
          <div class="pyf-product-price" style="color:var(--pyf-gold)">Drop Incoming</div>
          <button class="pyf-btn-notify" onclick="pyfOpenModal()">🔔 Notify Me at Launch</button>
        </div>
      </div>
    `;
  }

  // Fetch real product data from Shopify
  let imgSrc = null;
  let price = null;
  let variantId = null;

  try {
    const res = await fetch(`/products/${ferrule.handle}.js`);
    if (res.ok) {
      const data = await res.json();
      imgSrc = data.featured_image;
      price = (data.price / 100).toFixed(2);
      variantId = data.variants?.[0]?.id;
    }
  } catch(e) { /* fallback below */ }

  const imgHtml = imgSrc
    ? `<img src="${imgSrc}" alt="${ferrule.name}" loading="lazy">`
    : `<div class="pyf-product-img-placeholder">⛳</div>`;

  const priceHtml = price ? `$${price}` : '';

  const cartBtn = ferrule.configurator
    ? `<a class="pyf-btn-cart" href="/pages/feral-design-studio">Customize It &rarr;</a>`
    : variantId
      ? `<button class="pyf-btn-cart" id="cart-btn-${variantId}" onclick="pyfAddToCart(${variantId}, this)">+ Add to Cart</button>`
      : '';

  return `
    <div class="pyf-product-card${isTopPick ? ' top-pick' : ''}" style="position:relative">
      ${isTopPick ? '<span class="pyf-top-pick-badge">Top Match</span>' : ''}
      <div class="pyf-product-img-wrap">${imgHtml}</div>
      <div class="pyf-product-body">
        <div class="pyf-product-name">${ferrule.name}</div>
        <div class="pyf-product-tagline">${ferrule.tagline}</div>
        ${priceHtml ? `<div class="pyf-product-price">${priceHtml}</div>` : ''}
        <a class="pyf-btn-shop" href="/products/${ferrule.handle}">Shop Now &rarr;</a>
        ${cartBtn}
      </div>
    </div>
  `;
}

// ═══════════════════════════════════════════════════════════════
// ADD TO CART
// ═══════════════════════════════════════════════════════════════
async function pyfAddToCart(variantId, btn) {
  btn.textContent = 'Adding...';
  btn.classList.add('adding');
  try {
    const res = await fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: 1 })
    });
    if (res.ok) {
      btn.textContent = '✓ Added!';
      btn.style.color = 'var(--pyf-accent)';
      btn.style.borderColor = 'var(--pyf-accent)';
      setTimeout(() => {
        btn.textContent = '+ Add to Cart';
        btn.style.color = '';
        btn.style.borderColor = '';
        btn.classList.remove('adding');
      }, 2500);
    } else {
      btn.textContent = 'Error — try again';
      btn.classList.remove('adding');
    }
  } catch(e) {
    btn.textContent = 'Error — try again';
    btn.classList.remove('adding');
  }
}

// ═══════════════════════════════════════════════════════════════
// NOTIFY MODAL (Kyro Feral)
// ═══════════════════════════════════════════════════════════════
function pyfOpenModal() {
  document.getElementById('pyf-modal').classList.add('open');
}
function pyfCloseModal() {
  document.getElementById('pyf-modal').classList.remove('open');
}
async function pyfNotifySubmit() {
  const email = document.getElementById('pyf-notify-email').value.trim();
  if (!email || !email.includes('@')) {
    document.getElementById('pyf-notify-email').style.borderColor = 'var(--pyf-danger)';
    return;
  }
  // POST to Shopify Customer / Klaviyo / or your email capture endpoint
  // Replace the URL below with your actual email capture endpoint or Klaviyo list subscribe URL
  try {
    await fetch('/contact#contact_form', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams({
        form_type: 'customer',
        utf8: '✓',
        'contact[email]': email,
        'contact[body]': 'Kyro Feral launch notification signup via Pick Your Feral quiz'
      })
    });
  } catch(e) { /* silent fail */ }

  document.getElementById('pyf-modal').innerHTML = `
    <div class="pyf-modal">
      <div style="font-size:2rem;margin-bottom:12px">✅</div>
      <h3>You're on the list.</h3>
      <p style="margin-bottom:20px">We'll hit you the second the Kyro Feral drops. Stay feral.</p>
      <button class="pyf-modal-submit" onclick="pyfCloseModal()">Close</button>
    </div>
  `;
}
</script>

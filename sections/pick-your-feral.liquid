<style>
  :root {
    --pyf-bg: #1c302b;
    --pyf-card: #243d37;
    --pyf-border: #2e5048;
    --pyf-accent: #a1d9c6;
    --pyf-gold: #c8a84b;
    --pyf-text: #f1f3f3;
    --pyf-muted: #7aab9a;
    --pyf-danger: #e05c5c;
    --pyf-radius: 12px;
    --pyf-font: 'Rubik', system-ui, sans-serif;
  }

  .pyf-root * { box-sizing: border-box; margin: 0; padding: 0; }

  .pyf-root {
    font-family: var(--pyf-font);
    background: var(--pyf-bg);
    color: var(--pyf-text);
    min-height: 100vh;
    padding: 0;
  }

  /* ── HERO ─────────────────────────────────── */
  .pyf-hero {
    text-align: center;
    padding: 80px 24px 60px;
    max-width: 680px;
    margin: 0 auto;
  }
  .pyf-hero-eyebrow {
    font-size: .72rem;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--pyf-accent);
    margin-bottom: 16px;
  }
  .pyf-hero h1 {
    font-size: clamp(2.4rem, 7vw, 4rem);
    font-weight: 700;
    font-style: italic;
    line-height: 1.05;
    margin-bottom: 16px;
    color: var(--pyf-text);
  }
  .pyf-hero h1 span { color: var(--pyf-accent); }
  .pyf-hero-desc {
    font-size: 1rem;
    color: var(--pyf-muted);
    margin-bottom: 36px;
    line-height: 1.6;
  }
  .pyf-start-btn {
    background: var(--pyf-accent);
    color: #0d1f1a;
    font-family: var(--pyf-font);
    font-size: 1rem;
    font-weight: 700;
    padding: 16px 40px;
    border: none;
    border-radius: 50px;
    cursor: pointer;
    letter-spacing: .04em;
    transition: transform .15s, opacity .15s;
  }
  .pyf-start-btn:hover { opacity: .88; transform: translateY(-2px); }

  /* ── QUIZ SHELL ────────────────────────────── */
  .pyf-quiz {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 20px 80px;
  }

  /* Progress */
  .pyf-progress-wrap {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 40px;
    padding-top: 24px;
  }
  .pyf-progress-bar {
    flex: 1;
    height: 4px;
    background: var(--pyf-border);
    border-radius: 2px;
    overflow: hidden;
  }
  .pyf-progress-fill {
    height: 100%;
    background: var(--pyf-accent);
    border-radius: 2px;
    transition: width .4s ease;
  }
  .pyf-progress-label {
    font-size: .75rem;
    color: var(--pyf-muted);
    white-space: nowrap;
    font-weight: 600;
  }

  /* Question */
  .pyf-question {
    animation: pyf-fadeup .35s ease both;
  }
  @keyframes pyf-fadeup {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .pyf-q-eyebrow {
    font-size: .7rem;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--pyf-accent);
    margin-bottom: 10px;
  }
  .pyf-q-text {
    font-size: clamp(1.35rem, 4vw, 1.85rem);
    font-weight: 700;
    font-style: italic;
    line-height: 1.2;
    margin-bottom: 32px;
    color: var(--pyf-text);
  }

  /* Answer Cards */
  .pyf-answers {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }
  @media (max-width: 520px) {
    .pyf-answers { grid-template-columns: 1fr; }
  }
  .pyf-answer {
    background: var(--pyf-card);
    border: 2px solid var(--pyf-border);
    border-radius: var(--pyf-radius);
    padding: 20px 18px;
    cursor: pointer;
    transition: border-color .2s, background .2s, transform .15s;
    text-align: left;
    display: flex;
    align-items: flex-start;
    gap: 14px;
  }
  .pyf-answer:hover {
    border-color: var(--pyf-accent);
    background: #2a4a42;
    transform: translateY(-2px);
  }
  .pyf-answer.selected {
    border-color: var(--pyf-accent);
    background: #1e3d35;
  }
  .pyf-answer-icon {
    font-size: 1.6rem;
    flex-shrink: 0;
    line-height: 1;
    margin-top: 2px;
  }
  .pyf-answer-text {
    font-size: .92rem;
    font-weight: 600;
    color: var(--pyf-text);
    line-height: 1.4;
  }
  .pyf-answer-sub {
    font-size: .78rem;
    color: var(--pyf-muted);
    margin-top: 4px;
    font-weight: 400;
  }

  /* ── RESULTS ───────────────────────────────── */
  .pyf-results {
    max-width: 900px;
    margin: 0 auto;
    padding: 40px 20px 80px;
    animation: pyf-fadeup .4s ease both;
  }
  .pyf-results-header {
    text-align: center;
    margin-bottom: 48px;
  }
  .pyf-results-eyebrow {
    font-size: .72rem;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--pyf-accent);
    margin-bottom: 10px;
  }
  .pyf-results-headline {
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    font-weight: 700;
    font-style: italic;
    margin-bottom: 10px;
  }
  .pyf-results-sub {
    color: var(--pyf-muted);
    font-size: .95rem;
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* Product Grid */
  .pyf-product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 20px;
    margin-bottom: 40px;
  }
  .pyf-product-card {
    background: var(--pyf-card);
    border: 1px solid var(--pyf-border);
    border-radius: var(--pyf-radius);
    overflow: hidden;
    transition: transform .2s, box-shadow .2s;
    display: flex;
    flex-direction: column;
  }
  .pyf-product-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(0,0,0,.3);
  }
  .pyf-product-card.top-pick {
    border-color: var(--pyf-accent);
    position: relative;
  }
  .pyf-top-pick-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: var(--pyf-accent);
    color: #0d1f1a;
    font-size: .68rem;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 20px;
  }
  .pyf-product-card.coming-soon {
    border-color: var(--pyf-gold);
    opacity: .95;
  }
  .pyf-coming-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: var(--pyf-gold);
    color: #0d1f1a;
    font-size: .68rem;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 20px;
  }
  .pyf-product-img-wrap {
    width: 100%;
    aspect-ratio: 1;
    background: #1a2e28;
    overflow: hidden;
    position: relative;
  }
  .pyf-product-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform .3s;
  }
  .pyf-product-card:hover .pyf-product-img-wrap img {
    transform: scale(1.04);
  }
  .pyf-product-img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    background: linear-gradient(135deg, #1e3530, #2a4a42);
  }
  .pyf-product-body {
    padding: 18px 18px 20px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .pyf-product-name {
    font-size: 1rem;
    font-weight: 700;
    font-style: italic;
    margin-bottom: 4px;
    color: var(--pyf-text);
  }
  .pyf-product-tagline {
    font-size: .8rem;
    color: var(--pyf-muted);
    line-height: 1.5;
    margin-bottom: 14px;
    flex: 1;
  }
  .pyf-product-price {
    font-size: .88rem;
    font-weight: 600;
    color: var(--pyf-accent);
    margin-bottom: 12px;
  }
  .pyf-btn-shop {
    display: block;
    text-align: center;
    background: var(--pyf-accent);
    color: #0d1f1a;
    font-family: var(--pyf-font);
    font-size: .88rem;
    font-weight: 700;
    padding: 12px;
    border-radius: 8px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: opacity .15s;
    margin-bottom: 8px;
  }
  .pyf-btn-shop:hover { opacity: .85; }
  .pyf-btn-notify {
    display: block;
    text-align: center;
    background: transparent;
    color: var(--pyf-gold);
    font-family: var(--pyf-font);
    font-size: .88rem;
    font-weight: 700;
    padding: 12px;
    border-radius: 8px;
    border: 1.5px solid var(--pyf-gold);
    cursor: pointer;
    transition: background .15s, color .15s;
    margin-bottom: 8px;
    text-decoration: none;
  }
  .pyf-btn-notify:hover {
    background: var(--pyf-gold);
    color: #0d1f1a;
  }
  .pyf-btn-cart {
    display: block;
    text-align: center;
    background: transparent;
    color: var(--pyf-text);
    font-family: var(--pyf-font);
    font-size: .82rem;
    font-weight: 600;
    padding: 10px;
    border-radius: 8px;
    border: 1.5px solid var(--pyf-border);
    cursor: pointer;
    transition: border-color .15s, color .15s;
    width: 100%;
  }
  .pyf-btn-cart:hover { border-color: var(--pyf-accent); color: var(--pyf-accent); }
  .pyf-btn-cart.adding { opacity: .6; pointer-events: none; }

  /* Restart */
  .pyf-restart-wrap { text-align: center; }
  .pyf-restart-btn {
    background: transparent;
    border: 1.5px solid var(--pyf-border);
    color: var(--pyf-muted);
    font-family: var(--pyf-font);
    font-size: .85rem;
    padding: 12px 28px;
    border-radius: 50px;
    cursor: pointer;
    transition: border-color .2s, color .2s;
  }
  .pyf-restart-btn:hover { border-color: var(--pyf-accent); color: var(--pyf-accent); }

  /* Notify modal */
  .pyf-modal-overlay {
    display: none;
    position: fixed; inset: 0;
    background: rgba(0,0,0,.7);
    z-index: 9999;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }
  .pyf-modal-overlay.open { display: flex; }
  .pyf-modal {
    background: var(--pyf-card);
    border: 1px solid var(--pyf-gold);
    border-radius: 16px;
    padding: 36px 32px;
    max-width: 440px;
    width: 100%;
    text-align: center;
  }
  .pyf-modal h3 { font-size: 1.3rem; font-style: italic; font-weight: 700; margin-bottom: 8px; }
  .pyf-modal p { color: var(--pyf-muted); font-size: .88rem; margin-bottom: 20px; line-height: 1.5; }
  .pyf-modal input {
    width: 100%; padding: 12px 16px; border-radius: 8px;
    background: var(--pyf-bg); border: 1.5px solid var(--pyf-border);
    color: var(--pyf-text); font-family: var(--pyf-font); font-size: .92rem;
    margin-bottom: 10px;
  }
  .pyf-modal input:focus { outline: none; border-color: var(--pyf-gold); }
  .pyf-modal-submit {
    width: 100%; padding: 13px; border-radius: 8px;
    background: var(--pyf-gold); color: #0d1f1a;
    font-family: var(--pyf-font); font-weight: 700; font-size: .95rem;
    border: none; cursor: pointer; transition: opacity .15s;
    margin-bottom: 10px;
  }
  .pyf-modal-submit:hover { opacity: .85; }
  .pyf-modal-close {
    background: none; border: none; color: var(--pyf-muted);
    font-size: .82rem; cursor: pointer; text-decoration: underline; font-family: var(--pyf-font);
  }
</style>

<div class="pyf-root" id="pyf-root">

  <!-- ── HERO ─────────────────────────────────────── -->
  <div id="pyf-hero">
    <div class="pyf-hero">
      <div class="pyf-hero-eyebrow">Feral Golf Co.</div>
      <h1>Pick Your <span>Feral</span></h1>
      <p class="pyf-hero-desc">4 questions. We'll match you to the ferrule that fits your game, your personality, and your on-course energy.</p>
      <button class="pyf-start-btn" onclick="pyfStart()">Find My Ferrule &rarr;</button>
    </div>
  </div>

  <!-- ── QUIZ ──────────────────────────────────────── -->
  <div id="pyf-quiz" class="pyf-quiz" style="display:none">
    <div class="pyf-progress-wrap">
      <div class="pyf-progress-bar">
        <div class="pyf-progress-fill" id="pyf-progress-fill" style="width:0%"></div>
      </div>
      <div class="pyf-progress-label" id="pyf-progress-label">1 / 4</div>
    </div>
    <div id="pyf-question-wrap"></div>
  </div>

  <!-- ── RESULTS ────────────────────────────────────── -->
  <div id="pyf-results" class="pyf-results" style="display:none">
    <div class="pyf-results-header">
      <div class="pyf-results-eyebrow">Your Matches</div>
      <div class="pyf-results-headline" id="pyf-results-headline">Your Feral Ferrules</div>
      <p class="pyf-results-sub" id="pyf-results-sub"></p>
    </div>
    <div class="pyf-product-grid" id="pyf-product-grid"></div>
    <div class="pyf-restart-wrap">
      <button class="pyf-restart-btn" onclick="pyfRestart()">&larr; Start Over</button>
    </div>
  </div>

</div>

<!-- Notify Modal -->
<div class="pyf-modal-overlay" id="pyf-modal">
  <div class="pyf-modal">
    <div style="font-size:1.8rem;margin-bottom:12px">🔥</div>
    <h3>The Kyro Feral is Coming</h3>
    <p>Drop your email and you'll be first in line when the performance ferrule launches.</p>
    <input type="email" id="pyf-notify-email" placeholder="your@email.com">
    <button class="pyf-modal-submit" onclick="pyfNotifySubmit()">Notify Me</button>
    <button class="pyf-modal-close" onclick="pyfCloseModal()">No thanks</button>
  </div>
</div>

